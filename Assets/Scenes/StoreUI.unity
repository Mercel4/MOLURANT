    m_LineSpacing: 1
  m_Text: "\uC640\uCE74\uBAA8\uAC00 \uC9C4\uC815\uD55C \uD798\uC744 \uD574\uBC29\uD574
    \uC804\uBC29\uC5D0 \uAC70\uB300\uD55C \uBD89\uC740 \uB808\uC774\uC800\uB97C \uBC1C\uC0AC\uD569\uB2C8\uB2E4.
    \uB808\uC774\uC800\uC5D0 \uB9DE\uC740 \uC801\uC740 \uACF5\uACA9\uB825\uC758 200%
    \uD53C\uD574\uB97C \uC785\uACE0, 1\uCD08\uAC04 \uC774\uB3D9\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4.
    \uB2E8, \uC2A4\uD0AC \uC0AC\uC6A9 \uD6C4 5\uCD08\uAC04 \uC640\uCE74\uBAA8\uB294
    \uCCB4\uB825\uC744 \uD68C\uBCF5\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uC774\uB54C,
    \uC9C0\uC18D \uC2DC\uAC04 \uB3D9\uC548\uC740 \uB2E4\uB978 \uC2A4\uD0AC\uC744
    \uC0AC\uC6A9\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
